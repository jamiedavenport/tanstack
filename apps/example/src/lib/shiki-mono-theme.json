{
  "name": "mono",
  "type": "dark",
  "colors": {
    "editor.background": "#000000",
    "editor.foreground": "#ffffff"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#6b6b6b", "fontStyle": "italic" }
    },
    {
      "scope": ["string", "string.quoted", "string.template", "punctuation.definition.string"],
      "settings": { "foreground": "#c2a07a" }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.expression",
        "storage.type",
        "storage.modifier"
      ],
      "settings": { "foreground": "#8ba3c7", "fontStyle": "italic" }
    },
    {
      "scope": ["entity.name.function", "support.function", "meta.function-call"],
      "settings": { "foreground": "#ffffff" }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"],
      "settings": { "foreground": "#d6c098" }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.language.boolean",
        "constant.language.null"
      ],
      "settings": { "foreground": "#d6c098" }
    },
    {
      "scope": ["variable", "variable.parameter", "variable.other", "support.variable"],
      "settings": { "foreground": "#ffffff" }
    },
    {
      "scope": ["meta.object-literal.key", "meta.object.member", "variable.object.property"],
      "settings": { "foreground": "#dcdcdc" }
    },
    {
      "scope": ["punctuation", "meta.brace", "punctuation.separator", "punctuation.terminator"],
      "settings": { "foreground": "#9a9a9a" }
    },
    {
      "scope": ["keyword.operator", "keyword.operator.assignment"],
      "settings": { "foreground": "#9a9a9a" }
    }
  ]
}
